    "import ugradio as ugr\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# ============================================================\n",
    "# 1. Load data\n",
    "# ============================================================\n",
    "data = np.load(\"C:/Users/medin/Downloads/Spring_2026/ASTRON121/LAB3/DATA/RTFM_4_8_day.npz\", allow_pickle=True)\n",
    "jd = data['jd']\n",
    "spec_real = data['spec_real']\n",
    "spec_imag = data['spec_imag']\n",
    "\n",
    "# ============================================================\n",
    "# 2. Constants\n",
    "# ============================================================\n",
    "# Campbell Hall coordinates\n",
    "lat_deg = 37.873199\n",
    "lon_deg = -122.257063\n",
    "\n",
    "# Observing frequency (use 10.5 GHz as nominal, or extract from your data)\n",
    "freq_ghz = 10.5  # GHz\n",
    "c = 2.99792458e8  # m/s\n",
    "lambda_m = c / (freq_ghz * 1e9)  # ~0.02857 m\n",
    "\n",
    "# Sun declination (from your calculation)\n",
    "dec_mid_deg = 7.3376\n",
    "dec_mid_rad = dec_mid_deg * np.pi / 180\n",
    "cos_dec = np.cos(dec_mid_rad)\n",
    "sin_dec = np.sin(dec_mid_rad)\n",
    "sin_lat = np.sin(lat_deg * np.pi / 180)\n",
    "\n",
    "# ============================================================\n",
    "# 3. Hour angle for each observation\n",
    "# ============================================================\n",
    "# Get RA at midpoint\n",
    "jd_mid = np.median(jd)\n",
    "ra_mid_deg, _ = ugr.coord.sunpos(jd_mid)\n",
    "ra_mid_hours = ra_mid_deg / 15\n",
    "\n",
    "# LST for each observation\n",
    "lst_rad = np.array([ugr.timing.lst(jd=jd_i, lon=lon_deg) for jd_i in jd])\n",
    "lst_hours = lst_rad * 12 / np.pi\n",
    "\n",
    "# Hour angle in hours, then radians\n",
    "hour_angle_hours = lst_hours - ra_mid_hours\n",
    "hour_angle_hours = (hour_angle_hours + 12) % 24 - 12\n",
    "hour_angle_rad = hour_angle_hours * np.pi / 12\n",
    "\n",
    "print(f\"Hour angle range: {hour_angle_hours.min():.2f} to {hour_angle_hours.max():.2f} hours\")\n",
    "\n",
    "# ============================================================\n",
    "# 4. Choose a single frequency channel\n",
    "# ============================================================\n",
    "channel = 512\n",
    "vis_obs = spec_real[:, channel]  # use real part\n",
    "\n",
    "# Pre-compute sin and cos of hour angle\n",
    "sin_h = np.sin(hour_angle_rad)\n",
    "cos_h = np.cos(hour_angle_rad)\n",
    "\n",
    "# ============================================================\n",
    "# 5. Brute-force grid search for Q_ew and Q_ns\n",
    "# ============================================================\n",
    "# Expected Q_ew ~ (b_ew / lambda) * cos(dec)\n",
    "# With b_ew ~ 14.6 m, lambda ~ 0.02857 m, cos_dec ~ 0.992\n",
    "# Q_ew ~ (14.6 / 0.02857) * 0.992 ~ 507 wavelengths\n",
    "\n",
    "Q_ew_grid = np.linspace(400, 600, 40)\n",
    "Q_ns_grid = np.linspace(-150, 150, 40)\n",
    "\n",
    "S_grid = np.zeros((len(Q_ew_grid), len(Q_ns_grid)))\n",
    "\n",
    "print(\"Running grid search...\")\n",
    "for i, Q_ew in enumerate(Q_ew_grid):\n",
    "    for j, Q_ns in enumerate(Q_ns_grid):\n",
    "        # Argument of fringe: 2π * (Q_ew * sin_h + Q_ns * cos_h)\n",
    "        arg = 2 * np.pi * (Q_ew * sin_h + Q_ns * cos_h)\n",
    "        \n",
    "        # Design matrix for linear fit\n",
    "        X = np.column_stack([np.cos(arg), np.sin(arg)])\n",
    "        \n",
    "        # Linear least squares\n",
    "        A, B = np.linalg.lstsq(X, vis_obs, rcond=None)[0]\n",
    "        \n",
    "        # Model and residuals\n",
    "        model = A * np.cos(arg) + B * np.sin(arg)\n",
    "        residuals = vis_obs - model\n",
    "        S_grid[i, j] = np.sum(residuals**2)\n",
    "        \n",
    "print(\"Grid search complete.\")\n",
    "\n",
    "# Find minimum\n",
    "min_idx = np.unravel_index(np.argmin(S_grid), S_grid.shape)\n",
    "Q_ew_best = Q_ew_grid[min_idx[0]]\n",
    "Q_ns_best = Q_ns_grid[min_idx[1]]\n",
    "print(f\"Best fit: Q_ew = {Q_ew_best:.1f}, Q_ns = {Q_ns_best:.1f}\")\n",
    "\n",
    "# ============================================================\n",
    "# 6. Convert Q to baseline lengths in meters\n",
    "# ============================================================\n",
    "b_ew = Q_ew_best * lambda_m / cos_dec\n",
    "b_ns = Q_ns_best * lambda_m / (sin_lat * cos_dec)\n",
    "\n",
    "print(f\"\\nBest-fit baseline:\")\n",
    "print(f\"  b_ew = {b_ew:.2f} m\")\n",
    "print(f\"  b_ns = {b_ns:.2f} m\")\n",
    "print(f\"  Total baseline = {np.sqrt(b_ew**2 + b_ns**2):.2f} m\")\n",
    "\n",
    "# ============================================================\n",
    "# 7. Make the contour plot (Figure 2)\n",
    "# ============================================================\n",
    "fig, ax = plt.subplots(figsize=(9, 7))\n",
    "\n",
    "# Contour plot\n",
    "contour = ax.contour(Q_ns_grid, Q_ew_grid, S_grid, levels=15, cmap='viridis', linewidths=0.8)\n",
    "ax.clabel(contour, inline=True, fontsize=8, fmt='%.0f')\n",
    "contourf = ax.contourf(Q_ns_grid, Q_ew_grid, S_grid, levels=15, cmap='viridis', alpha=0.5)\n",
    "\n",
    "# Mark the minimum\n",
    "ax.plot(Q_ns_best, Q_ew_best, 'r*', markersize=15, label=f'Minimum\\nQ_ew={Q_ew_best:.1f}\\nQ_ns={Q_ns_best:.1f}')\n",
    "\n",
    "ax.set_xlabel('$Q_{ns}$ (wavelengths)', fontsize=12)\n",
    "ax.set_ylabel('$Q_{ew}$ (wavelengths)', fontsize=12)\n",
    "ax.set_title('Figure 2: Brute-Force Least-Squares Residuals\\nfor Baseline Determination', fontsize=14)\n",
    "ax.legend(loc='upper right')\n",
    "plt.colorbar(contourf, label='Sum of Squared Residuals $S$')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
