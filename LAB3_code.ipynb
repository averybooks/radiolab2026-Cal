   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from rafpy.fitting import brute_force_fit, nonlinear_fit, recover_baseline\n",
    "from rafpy.params import C, FREQ_RF, LAT\n",
    "from rafpy.visibility import fourier_filter_fringe\n",
    "\n",
    "N_integrations = len(times)\n",
    "dt = 10  # 40 seconds per integration\n",
    "unix_times = data[\"start_time\"]\n",
    "\n",
    "# Mock Alt/Az coordinates\n",
    "alt_deg = data[\"scope_alt\"]\n",
    "az_deg = data[\"scope_az\"]\n",
    "\n",
    "lam = C / (1.54*1e9) \n",
    "\n",
    "# Average the real visibilities across the middle channels\n",
    "chan_lo, chan_hi = 500, 800\n",
    "band_real = np.mean(real_centered[:, chan_lo:chan_hi], axis=1)\n",
    "\n",
    "# Apply Fourier Band-Pass Filter\n",
    "band_real_filt = fourier_filter_fringe(\n",
    "    band_real, \n",
    "    dt=dt,\n",
    "    f_lo=0.0005,\n",
    "    f_hi=0.01\n",
    ")\n",
    "\n",
    "# Convert Alt / Az to Hour Angle (h_s) and Declination (delta)\n",
    "alt_rad = np.radians(alt_deg)\n",
    "az_rad = np.radians(az_deg)\n",
    "\n",
    "sin_delta = np.sin(LAT) * np.sin(alt_rad) + np.cos(LAT) * np.cos(alt_rad) * np.cos(az_rad)\n",
    "delta_rad = np.arcsin(sin_delta)\n",
    "\n",
    "sin_h = -np.sin(az_rad) * np.cos(alt_rad) / np.cos(delta_rad)\n",
    "cos_h = (np.sin(alt_rad) - np.sin(LAT) * np.sin(delta_rad)) / (np.cos(LAT) * np.cos(delta_rad))\n",
    "h_s = np.arctan2(sin_h, cos_h)\n",
    "\n",
    "delta_mean = np.mean(delta_rad)\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# 2. FRINGE FITTING\n",
    "# ---------------------------------------------------------\n",
    "print(\"Running brute-force fit...\")\n",
    "bf_result = brute_force_fit(\n",
    "    h_s=h_s, \n",
    "    F_obs=band_real_filt, \n",
    "    b_ew_approx=14.6, \n",
    "    n_ns=400,\n",
    "    Q_ew_range=(72, 73.5),\n",
    "    Q_ns_range=(0, 1.5),\n",
    "    lam=lam\n",
    ")\n",
    "\n",
    "print(\"Refining with non-linear fit...\")\n",
    "nl_result = nonlinear_fit(h_s, band_real_filt, bf_result)\n",
    "\n",
    "# Extract best-fit parameters\n",
    "best_Q_ew = nl_result['Q_ew']\n",
    "best_Q_ns = nl_result['Q_ns']\n",
    "\n",
    "# Extract formal errors from Levenberg-Marquardt covariance matrix\n",
    "sigma_Q_ew = nl_result['sigma_Q_ew']\n",
    "sigma_Q_ns = nl_result['sigma_Q_ns']\n",
    "\n",
    "# Extract cross-covariance between Q_ew (index 2) and Q_ns (index 3)\n",
    "cov_Qew_Qns = nl_result['cov'][2, 3] \n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# 3. EXTRACT TOTAL BASELINE & PROPAGATE ERRORS\n",
    "# ---------------------------------------------------------\n",
    "b_ew, b_ns = recover_baseline(\n",
    "    Q_ew=best_Q_ew, \n",
    "    Q_ns=best_Q_ns, \n",
    "    delta=delta_mean, \n",
    "    lat=LAT, \n",
    "    lam=lam\n",
    ")\n",
    "b_total = np.sqrt(b_ew**2 + b_ns**2)\n",
    "\n",
    "# Geometric Scaling Factors\n",
    "scale_ew = lam / np.cos(delta_mean)\n",
    "scale_ns = lam / (np.sin(LAT) * np.cos(delta_mean))\n",
    "\n",
    "# Propagate to Baseline Components\n",
    "sigma_b_ew = sigma_Q_ew * scale_ew\n",
    "sigma_b_ns = sigma_Q_ns * scale_ns\n",
    "cov_b_ew_ns = cov_Qew_Qns * (scale_ew * scale_ns)\n",
    "\n",
    "# Propagate to Total Baseline\n",
    "if b_total > 0:\n",
    "    variance_b = (1 / b_total**2) * (\n",
    "        (b_ew**2 * sigma_b_ew**2) + \n",
    "        (b_ns**2 * sigma_b_ns**2) + \n",
    "        (2 * b_ew * b_ns * cov_b_ew_ns)\n",
    "    )\n",
    "    sigma_b_total = np.sqrt(abs(variance_b))\n",
    "else:\n",
    "    sigma_b_total = 0.0\n",
    "\n",
    "print(f\"\\n--- Baseline Results ---\")\n",
    "print(f\"Solar Declination: {np.degrees(delta_mean):.2f} degrees\")\n",
    "print(f\"Fitted Q_ew: {best_Q_ew:.2f} ± {sigma_Q_ew:.4f}\")\n",
    "print(f\"Fitted Q_ns: {best_Q_ns:.2f} ± {sigma_Q_ns:.4f}\")\n",
    "print(f\"East-West Baseline (b_ew): {b_ew:.4f} ± {sigma_b_ew:.4f} meters\")\n",
    "print(f\"North-South Baseline (b_ns): {b_ns:.4f} ± {sigma_b_ns:.4f} meters\")\n",
    "print(f\"Total Baseline Magnitude (b): {b_total:.4f} ± {sigma_b_total:.4f} meters\")\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# 4. PLOTTING THE HEATMAP & 2-SIGMA ELLIPSE (b-space)\n",
    "# ---------------------------------------------------------\n",
    "# 4a. Get the meshes from the brute-force grid\n",
    "Q_ew_grid = bf_result.get('Q_ew_grid', bf_result.get('Q_ew_arr'))\n",
    "Q_ns_grid = bf_result.get('Q_ns_grid', bf_result.get('Q_ns_arr'))\n",
    "S_grid = bf_result['S_grid']\n",
    "\n",
    "Q_ew_mesh, Q_ns_mesh = np.meshgrid(Q_ew_grid, Q_ns_grid, indexing='ij')\n",
    "\n",
    "# Convert meshes to physical coordinates (meters)\n",
    "b_ew_mesh = Q_ew_mesh * lam / np.cos(delta_mean)\n",
    "b_ns_mesh = Q_ns_mesh * lam / (np.cos(delta_mean) * np.sin(LAT))\n",
    "\n",
    "# 4b. Reconstruct the 2x2 Sub-Covariance Matrix (in Q-space)\n",
    "cov_matrix = np.array([\n",
    "    [sigma_Q_ew**2, cov_Qew_Qns],\n",
    "    [cov_Qew_Qns, sigma_Q_ns**2]\n",
    "])\n",
    "inv_cov = np.linalg.inv(cov_matrix)\n",
    "\n",
    "# 4c. Calculate the Analytic Delta Chi-Squared Surface\n",
    "dQ_ew = Q_ew_mesh - best_Q_ew\n",
    "dQ_ns = Q_ns_mesh - best_Q_ns\n",
    "\n",
    "delta_chi2_surface = (\n",
    "    inv_cov[0, 0] * dQ_ew**2 + \n",
    "    2 * inv_cov[0, 1] * dQ_ew * dQ_ns + \n",
    "    inv_cov[1, 1] * dQ_ns**2\n",
    ")"
   ]
