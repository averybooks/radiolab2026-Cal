    "def compute_power_spectrum(real_part, imag_part):\n",
    "    \"\"\"\n",
    "    Computes the power spectrum (squared magnitude) from real and imaginary components.\n",
    "    \n",
    "    Parameters:\n",
    "    real_part (np.ndarray): Array of real components (e.g., shape 910x1024)\n",
    "    imag_part (np.ndarray): Array of imaginary components (same shape)\n",
    "    \n",
    "    Returns:\n",
    "    np.ndarray: The power spectrum (same shape)\n",
    "    \"\"\"\n",
    "    # Calculation: P = Real^2 + Imag^2\n",
    "    # This is equivalent to np.abs(complex_data)**2 but faster \n",
    "    # because it avoids creating a complex object in memory.\n",
    "    power_spectrum = np.square(real_part) + np.square(imag_part)\n",
    "    \n",
    "    return power_spectrum"
   ]
  },
