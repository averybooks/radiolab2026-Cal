    "import numpy as np\n",
    "from scipy.optimize import curve_fit\n",
    "from rafpy.modulator import mf_theory\n",
    "\n",
    "# Get the normalized MF_obs (you already have these)\n",
    "ff_rad = mf_obs_result['ff_rad_bins']\n",
    "mf_obs = mf_obs_result['mf_obs']\n",
    "n_in_bin = mf_obs_result['n_in_bin']\n",
    "\n",
    "# Filter: only bins with at least 1 sample and finite MF\n",
    "good = (n_in_bin > 0) & np.isfinite(mf_obs)\n",
    "ff_g = ff_rad[good]\n",
    "mf_g = mf_obs[good]\n",
    "\n",
    "print(f\"Number of good bins: {good.sum()}\")\n",
    "print(f\"ff_rad range: {ff_g.min():.2f} to {ff_g.max():.2f}\")\n",
    "\n",
    "# Define the model function for fitting\n",
    "def mf_model(ff, R_deg):\n",
    "    \"\"\"\n",
    "    ff: local fringe frequency (cycles/radian)\n",
    "    R_deg: angular radius in degrees\n",
    "    Returns: normalized fringe modulator\n",
    "    \"\"\"\n",
    "    R_rad = np.radians(R_deg)\n",
    "    mf = mf_theory(ff * R_rad)\n",
    "    # Normalize to 1 at ff=0\n",
    "    mf = mf / mf[0] if len(mf) > 0 else mf\n",
    "    return mf\n",
    "\n",
    "# Fit the data\n",
    "try:\n",
    "    # Initial guess: 0.25 degrees radius (0.5 degree diameter)\n",
    "    popt, pcov = curve_fit(mf_model, ff_g, mf_g, p0=[0.25])\n",
    "    R_best_deg = popt[0]\n",
    "    R_err_deg = np.sqrt(pcov[0, 0])\n",
    "    \n",
    "    print(f\"\\n--- Solar Diameter Results (Manual Fit) ---\")\n",
    "    print(f\"Best-fit radius: {R_best_deg:.3f}° ± {R_err_deg:.3f}°\")\n",
    "    print(f\"Best-fit diameter: {2*R_best_deg:.3f}° ± {2*R_err_deg:.3f}°\")\n",
    "    print(f\"Expected diameter: ~0.53° (32 arcmin)\")\n",
    "    \n",
    "except Exception as e:\n",
    "    print(f\"Fit failed: {e}\")\n",
    "    R_best_deg = 0.265  # fallback to expected radius\n",
    "    print(\"Using expected radius as fallback\")\n",
    "\n",
    "# Plot the result\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 5))\n",
    "\n",
    "# Plot data points\n",
    "ax.errorbar(ff_g, mf_g, fmt='o', ms=5, color='steelblue', \n",
    "            label='MF_observed (normalized)', alpha=0.7, capsize=3)\n",
    "\n",
    "# Plot theoretical curve for best-fit\n",
    "ff_theory = np.linspace(0, ff_g.max() * 1.2, 500)\n",
    "mf_theory_vals = mf_model(ff_theory, R_best_deg)\n",
    "ax.plot(ff_theory, mf_theory_vals, 'r-', lw=2,\n",
    "        label=f'MF_theory: diameter = {2*R_best_deg:.3f}°')\n",
    "\n",
    "ax.axhline(0, color='k', lw=0.8, alpha=0.5)\n",
    "ax.set_xlabel('Local fringe frequency $f_f$ (cycles/radian)', fontsize=12)\n",
    "ax.set_ylabel('Normalized Fringe Modulator', fontsize=12)\n",
    "ax.set_title('Solar Diameter Fit: Normalized MF_obs vs. MF_theory', fontsize=12)\n",
    "ax.legend()\n",
    "ax.grid(True, alpha=0.3)\n",
    "\n",
    "# Add annotations\n",
    "ax.text(0.05, 0.95, f'Best fit: {2*R_best_deg:.2f}° diameter\\nExpected: ~0.53° (32 arcmin)',\n",
    "        transform=ax.transAxes, verticalalignment='top',\n",
    "        bbox=dict(boxstyle='round', facecolor='wheat', alpha=0.8))\n",
    "\n",
    "# Mark the first null location if within range\n",
    "first_null_ff = 0.61 / np.radians(R_best_deg)\n",
    "if first_null_ff < ff_g.max():\n",
    "    ax.axvline(first_null_ff, color='purple', linestyle=':', alpha=0.7,\n",
    "               label=f'First null at ff ≈ {first_null_ff:.1f}')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# Also plot chi-squared scan manually\n",
    "R_try_deg = np.linspace(0.1, 0.6, 500)\n",
    "chi2 = np.zeros_like(R_try_deg)\n",
    "\n",
    "for i, R_deg in enumerate(R_try_deg):\n",
    "    mf_model_vals = mf_model(ff_g, R_deg)\n",
    "    chi2[i] = np.sum((mf_g - mf_model_vals)**2)\n",
    "\n",
    "i_best = np.argmin(chi2)\n",
    "R_chi2_best = R_try_deg[i_best]\n",
    "\n",
    "fig2, ax2 = plt.subplots(figsize=(8, 4))\n",
    "ax2.plot(R_try_deg * 2, chi2, 'b-', linewidth=1.5)  # x-axis as diameter\n",
    "ax2.axvline(2*R_chi2_best, color='r', linestyle='--', label=f\"Best diameter: {2*R_chi2_best:.3f}°\")\n",
    "ax2.set_xlabel('Angular diameter (degrees)')\n",
    "ax2.set_ylabel('Chi-squared (unweighted)')\n",
    "ax2.set_title('Diameter Fit: Chi-squared vs. Angular Diameter')\n",
    "ax2.legend()\n",
    "ax2.grid(True, alpha=0.3)\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
