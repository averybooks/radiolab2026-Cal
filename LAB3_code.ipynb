    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from rafpy.modulator import mf_observed, fit_diameter, mf_theory\n",
    "from scipy.signal import savgol_filter\n",
    "from scipy.signal import envelope\n",
    "\n",
    "# Compute the envelope directly\n",
    "envelope = envelope(real_centered[:, 550])\n",
    "envelope_smoothed = savgol_filter(envelope[0], window_length=19, polyorder=3)\n",
    "\n",
    "def bessel_fringe_model(ff, radius_radians, amplitude=1.0):\n",
    "    \"\"\"\n",
    "    Theoretical visibility amplitude for a uniform circular disk.\n",
    "    ff: Local fringe frequency in cycles per radian.\n",
    "    radius_radians: Angular radius of the source in radians.\n",
    "    \"\"\"\n",
    "    # The argument for the Bessel function is x = 2 * pi * ff * R\n",
    "    x = ff * radius_radians\n",
    "    \n",
    "    # The model is 2 * J1(x) / x. We use a mask to avoid division by zero at x=0\n",
    "    # At x=0, the limit of 2*J1(x)/x is 1.0.\n",
    "    visibility = np.zeros_like(x)\n",
    "    non_zero = x != 0\n",
    "    visibility[non_zero] = amplitude * (2 * j1(x[non_zero]) / x[non_zero])\n",
    "    visibility[~non_zero] = amplitude \n",
    "    \n",
    "    return visibility\n",
    "\n",
    "R = 0.03\n",
    "AMP = 10\n",
    "# Conversion from Hz (1/sec) to cycles/radian\n",
    "sidereal_day_sec = 86164.09\n",
    "nu_f_rad = nu_f * (sidereal_day_sec / (2 * np.pi))\n",
    "bessel = bessel_fringe_model(nu_f_rad, R, amplitude = AMP)\n",
    "\n",
    "MF_theo = AMP*mf_theory(nu_f_rad*R)\n",
    "\n",
    "plt.figure(figsize=(10,3))\n",
    "plt.scatter(h_s, real_centered[:, 550], s=1)\n",
    "plt.plot(h_s, envelope_smoothed, color = \"green\")\n",
    "plt.plot(h_s, -envelope_smoothed, color = \"green\")\n",
    "plt.plot(h_s-.12, (bessel), color = \"orange\", lw = 2)\n",
    "plt.plot(h_s-.12, MF_theo, color=\"red\")\n",
    "plt.axhline(0, color=\"black\")\n",
    "# plt.ylim(-2.5, 2.5)\n",
    "plt.xlim(h_s[0], h_s[-1])\n",
    "\n",
    "plt.show()\n",
    "\n",
    "# 1. Find OBSERVED roots in terms of fringe frequency (nu_f_rad), not hour angle\n",
    "sign_changes_obs = np.where(np.diff(np.sign(bessel)))[0]\n",
    "\n",
    "roots_obs_ff = []\n",
    "for i in sign_changes_obs:\n",
    "    # Interpolate over nu_f_rad!\n",
    "    x0, x1 = nu_f_rad[i], nu_f_rad[i+1] \n",
    "    y0, y1 = bessel[i], bessel[i+1]\n",
    "    \n",
    "    root = x0 - y0 * (x1 - x0) / (y1 - y0)\n",
    "    roots_obs_ff.append(root)\n",
    "\n",
    "# 2. Find THEORETICAL roots in terms of the variable (f_f * R)\n",
    "# We create a generic test array for the product (f_f * R) to find the math's intrinsic zeroes\n",
    "ff_R_test = np.linspace(0.1, 3.0, 1000) \n",
    "theory_curve_generic = mf_theory(ff_R_test) \n",
    "\n",
    "sign_changes_theory = np.where(np.diff(np.sign(theory_curve_generic)))[0]\n",
    "\n",
    "roots_theory_ff_R = []\n",
    "for i in sign_changes_theory:\n",
    "    # Interpolate over the test array\n",
    "    x0, x1 = ff_R_test[i], ff_R_test[i+1]\n",
    "    y0, y1 = theory_curve_generic[i], theory_curve_generic[i+1]\n",
    "    \n",
    "    root = x0 - y0 * (x1 - x0) / (y1 - y0)\n",
    "    roots_theory_ff_R.append(root)\n",
    "\n",
    "# 3. Calculate Final Radius R\n",
    "# Now the math works: (f_f * R) / f_f = R\n",
    "min_len = min(len(roots_theory_ff_R), len(roots_obs_ff))\n",
    "calculated_R_values = []\n",
    "\n",
    "print(\"\\n--- Final Radius Calculation ---\")\n",
    "for k in range(min_len):\n",
    "    R_calc = roots_theory_ff_R[k] / roots_obs_ff[k]\n",
    "    calculated_R_values.append(R_calc)\n",
